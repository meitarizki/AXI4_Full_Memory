{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build SystemC Project",
            "command": "/usr/bin/g++",
            "args": [
                "-std=c++17",
                "-I/opt/homebrew/include",
                "-L/opt/homebrew/lib",
                "-lsystemc",
                "main.cpp",
                "-o",
                "simulation"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compiler: /usr/bin/g++"
        }
    ]
}
